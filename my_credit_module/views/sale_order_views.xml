<odoo>
    <record id="view_sale_order_form_credit" model="ir.ui.view">
        <field name="name">sale.order.form.credit</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet/notebook" position="before">
                <group>
                    <field name="remaining_credit" readonly="1"/>
                </group>
            </xpath>

            <xpath expr="//header" position="inside">
                <button name="open_approval"
                        string="Approval"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-check"/>
            </xpath>
        </field>
    </record>
</odoo>
